Window main_window {
    title: "3D Display Control Panel";
    default-width: 200;
    default-height: 200;

    Stack main_stack {
        name: "main_stack";
            
        StackPage {
            name: "main_box";
            title: "Main Menu";
            child: main_box;
        }        

        StackPage {
            name: "main_fov_calibration_box";
            title: "Calibration";
            child : main_fov_calibration_box;
        }

        StackPage {
            name: "second_fov_calibration_box";
            title: "Calibration";
            child : second_fov_calibration_box;
        }

        StackPage {
            name: "measurements_calibration_box";
            title: "Calibration";
            child : measurements_calibration_box;
        }

        StackPage {
            name: "display_density_calibration_box";
            title: "display_density_calibration_box";
            child: display_density_calibration_box;
        }

        StackPage {
            name: "main_horizontal_offset_calibration_box";
            title: "main_horizontal_offset_calibration_box";
            child: main_horizontal_offset_calibration_box;
        }

        StackPage {
            name: "main_vertical_offset_calibration_box";
            title: "main_vertical_offset_calibration_box";
            child: main_vertical_offset_calibration_box;
        }

        StackPage {
            name: "second_horizontal_offset_calibration_box";
            title: "second_horizontal_offset_calibration_box";
            child: second_horizontal_offset_calibration_box;
        }

        StackPage {
            name: "second_vertical_offset_calibration_box";
            title: "second_vertical_offset_calibration_box";
            child: second_vertical_offset_calibration_box;
        }
        
    }
}